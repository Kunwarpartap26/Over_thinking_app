<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D0D"
    android:gravity="center"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TETRA"
        android:textSize="48sp"
        android:textColor="#5C6BC0"
        android:textStyle="bold"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Truthful Mentor — 100% Offline"
        android:textSize="13sp"
        android:textColor="#777777"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🧠 AI Brain Setup"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <ProgressBar
        android:id="@+id/progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#5C6BC0"/>

    <TextView
        android:id="@+id/percent_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0%"
        android:textColor="#5C6BC0"
        android:textSize="14sp"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ready to setup"
        android:textColor="#9E9E9E"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/download_btn"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="⬇️ Auto Download (WiFi)"
        android:backgroundTint="#5C6BC0"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/manual_btn"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="📋 Manual Setup Instructions"
        android:backgroundTint="#37474F"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/skip_btn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Skip (limited mode)"
        android:backgroundTint="#1E1E1E"
        android:textColor="#777777"/>

</LinearLayout>
