<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D0D">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TETRA"
            android:textSize="28sp"
            android:textColor="#5C6BC0"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/save_button"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="💾 Save PDF"
            android:backgroundTint="#1B5E20"
            android:textColor="#FFFFFF"
            android:textSize="12sp"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E1E1E"/>

    <!-- Chat log -->
    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp">

        <TextView
            android:id="@+id/session_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:hint="Apne thoughts yahan share karo..."
            android:textColorHint="#555555"/>

    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E1E1E"/>

    <!-- Input area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/input_box"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Type karo ya mic use karo..."
            android:textColor="#FFFFFF"
            android:textColorHint="#777777"
            android:background="#1E1E1E"
            android:padding="12dp"
            android:textSize="14sp"
            android:imeOptions="actionSend"
            android:inputType="textMultiLine"
            android:maxLines="3"/>

        <Button
            android:id="@+id/send_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="➤"
            android:backgroundTint="#5C6BC0"
            android:textColor="#FFFFFF"
            android:layout_marginStart="6dp"
            android:textSize="16sp"/>

        <Button
            android:id="@+id/mic_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="🎤"
            android:backgroundTint="#37474F"
            android:textColor="#FFFFFF"
            android:layout_marginStart="6dp"
            android:textSize="16sp"/>

    </LinearLayout>

</LinearLayout>
