<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D0D"
    android:gravity="center"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TETRA"
        android:textSize="32sp"
        android:textColor="#5C6BC0"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/pin_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PIN daalo"
        android:textSize="16sp"
        android:textColor="#9E9E9E"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/pin_display"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="○ ○ ○ ○"
        android:textSize="32sp"
        android:textColor="#5C6BC0"
        android:letterSpacing="0.3"
        android:layout_marginBottom="40dp"/>

    <!-- Row 1 -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="12dp">
        <Button android:id="@+id/btn1" android:layout_width="80dp"
            android:layout_height="80dp" android:text="1"
            android:textSize="24sp" android:backgroundTint="#1E1E1E"
            android:textColor="#FFFFFF" android:layout_marginEnd="12dp"/>
        <Button android:id="@+id/btn2" android:layout_width="80dp"
            android:layout_height="80dp" android:text="2"
            android:textSize="24sp" android:backgroundTint="#1E1E1E"
            android:textColor="#FFFFFF" android:layout_marginEnd="12dp"/>
        <Button android:id="@+id/btn3" android:layout_width="80dp"
            android:layout_height="80dp" android:text="3"
            android:textSize="24sp" android:backgroundTint="#1E1E1E"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- Row 2 -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="12dp">
        <Button android:id="@+id/btn4" android:layout_width="80dp"
            android:layout_height="80dp" android:text="4"
            android:textSize="24sp" android:backgroundTint="#1E1E1E"
            android:textColor="#FFFFFF" android:layout_marginEnd="12dp"/>
        <Button android:id="@+id/btn5" android:layout_width="80dp"
            android:layout_height="80dp" android:text="5"
            android:textSize="24sp" android:backgroundTint="#1E1E1E"
            android:textColor="#FFFFFF" android:layout_marginEnd="12dp"/>
        <Button android:id="@+id/btn6" android:layout_width="80dp"
            android:layout_height="80dp" android:text="6"
            android:textSize="24sp" android:backgroundTint="#1E1E1E"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- Row 3 -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="12dp">
        <Button android:id="@+id/btn7" android:layout_width="80dp"
            android:layout_height="80dp" android:text="7"
            android:textSize="24sp" android:backgroundTint="#1E1E1E"
            android:textColor="#FFFFFF" android:layout_marginEnd="12dp"/>
        <Button android:id="@+id/btn8" android:layout_width="80dp"
            android:layout_height="80dp" android:text="8"
            android:textSize="24sp" android:backgroundTint="#1E1E1E"
            android:textColor="#FFFFFF" android:layout_marginEnd="12dp"/>
        <Button android:id="@+id/btn9" android:layout_width="80dp"
            android:layout_height="80dp" android:text="9"
            android:textSize="24sp" android:backgroundTint="#1E1E1E"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- Row 4 -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">
        <Button android:id="@+id/btn_clear" android:layout_width="80dp"
            android:layout_height="80dp" android:text="⌫"
            android:textSize="24sp" android:backgroundTint="#37474F"
            android:textColor="#FFFFFF" android:layout_marginEnd="12dp"/>
        <Button android:id="@+id/btn0" android:layout_width="80dp"
            android:layout_height="80dp" android:text="0"
            android:textSize="24sp" android:backgroundTint="#1E1E1E"
            android:textColor="#FFFFFF" android:layout_marginEnd="12dp"/>
        <View android:layout_width="80dp" android:layout_height="80dp"/>
    </LinearLayout>

</LinearLayout>
